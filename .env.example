# Gemini (Google AI Studio — free tier available)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# PubMed (optional — raises rate limit from 3 to 10 req/s)
# Get one free at: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# Gmail SMTP
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com → Security → App passwords
# 3. Generate a password for "Mail"
SMTP_USER=your.address@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Email addresses
SENDER_EMAIL=your.address@gmail.com
RECIPIENT_EMAILS=recipient1@example.com,recipient2@example.com

# Digest settings
DIGEST_TITLE=Weekly Oncology Research Digest
